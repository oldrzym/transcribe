# Runtime directories persisted by Docker named volumes.
APP_WORK_DIR=/work
TORCH_HOME=/models/torch
GIGAAM_CACHE_DIR=/models/gigaam

# ASR runtime.
APP_DEVICE=cuda
DEFAULT_ENHANCE_AUDIO_MODE=auto

# GigaAM `.transcribe()` supports up to 25-second chunks; 22s keeps a safety margin.
DEFAULT_CHUNK_SECONDS=22.0
MIN_CHUNK_SECONDS=1.0
MAX_CHUNK_SECONDS=25.0

# Auto-quality heuristics.
# Speech quieter than -30 dBFS is considered weak for direct ASR.
AUTO_QUALITY_QUIET_SPEECH_DBFS=-30.0
# If speech is less than 12 dB above pauses/background, the record is treated as noisy.
AUTO_QUALITY_SNR_THRESHOLD_DB=12.0
# More than 0.5% clipped samples is enough to flag clipping artifacts.
AUTO_QUALITY_CLIPPING_RATIO_THRESHOLD=0.005
# Warn when speech occupies less than 20% of the recording.
AUTO_QUALITY_LOW_SPEECH_RATIO_THRESHOLD=0.20
# Enable enhancement when the summed heuristic score reaches this value.
AUTO_QUALITY_ENABLE_THRESHOLD=1.0
