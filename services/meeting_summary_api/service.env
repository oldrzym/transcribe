# Runtime working directory for uploaded files and temporary artifacts.
APP_WORK_DIR=/work

# Internal HTTP endpoints of dependent services inside docker compose.
GIGAAM_API_BASE_URL=http://gigaam-api:8080
VLLM_API_BASE_URL=http://vllm-qwen:8000/v1
VLLM_MODEL_NAME=qwen3-32b-awq

# Long audio and sequential LLM summarization can take substantial time.
HTTP_TIMEOUT_SECONDS=1800
# Wait for upstream services on startup instead of booting into a broken state.
DEPENDENCY_WAIT_TIMEOUT_SECONDS=900
DEPENDENCY_WAIT_INTERVAL_SECONDS=5

# Pass-through defaults for the upstream GigaAM transcription request.
DEFAULT_ASR_CHUNK_SECONDS=22.0
MIN_ASR_CHUNK_SECONDS=1.0
MAX_ASR_CHUNK_SECONDS=25.0
DEFAULT_ENHANCE_AUDIO_MODE=auto

# LLM chunking is based on central ASR-derived chunks with compact neighbor context.
# 1200 words is a practical default for an 8k-context summarization model.
SUMMARY_MAX_WORDS=1200
# Char limit is a second guardrail in case transcript wording is unusually dense.
SUMMARY_MAX_CHARS=9000
# Reuse up to 250 words from neighbor chunks only as context for the central chunk.
SUMMARY_CONTEXT_WORDS=250

# Conservative generation settings for deterministic business summaries.
LLM_TEMPERATURE=0.1
LLM_CHUNK_MAX_TOKENS=900
LLM_FINAL_MAX_TOKENS=1400
LLM_ENABLE_THINKING=false
