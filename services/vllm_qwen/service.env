# Runtime model path baked into the image during docker build.
VLLM_MODEL_PATH=/opt/models/qwen3-32b-awq

# Name exposed through the OpenAI-compatible API.
VLLM_SERVED_MODEL_NAME=qwen3-32b-awq

# One 40 GB GPU is the target profile for this service.
VLLM_TENSOR_PARALLEL_SIZE=1

# 8k context is a safer default for a 32B AWQ model on a single 40 GB GPU.
VLLM_MAX_MODEL_LEN=8192

# vLLM pre-allocates this share of GPU memory; keep some headroom for CUDA graphs.
VLLM_GPU_MEMORY_UTILIZATION=0.88
