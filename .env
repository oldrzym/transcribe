# Port published on the host machine.
GIGAAM_API_PORT=8080

# Model version is reused both at image build time and at runtime.
GIGAAM_MODEL=v3_e2e_rnnt

# GPU assignment for the ASR service. Use a concrete index like `0` or `1` on multi-GPU hosts.
GIGAAM_GPU_DEVICE=0

# vLLM Qwen service.
VLLM_QWEN_PORT=8001
VLLM_QWEN_MODEL_REPO=Qwen/Qwen3-32B-AWQ

# GPU assignment for the vLLM service. On a single-GPU host this will be the same device.
VLLM_GPU_DEVICE=0

# Meeting summary API port on the host machine.
MEETING_SUMMARY_API_PORT=8082

# Frontend port on the host machine.
MEETING_SUMMARY_WEB_PORT=8083
